{% doc %}
  @prompt
    Need a section where i have 4 elements with Text image in the background and button to click. the forward to page x with collections. , Can we make showing always 2 and that it slides every 4 seconds on the right ?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .ai-collection-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-collection-carousel__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.grid_gap }}px;
    transition: transform 0.5s ease-in-out;
  }

  .ai-collection-carousel__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    height: {{ block.settings.card_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: calc((100% - {{ block.settings.grid_gap }}px) / 2);
  }

  .ai-collection-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-collection-carousel__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .ai-collection-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-collection-carousel__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 20px;
    width: 100%;
  }

  .ai-collection-carousel__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.button_spacing }}px;
    font-weight: 600;
  }

  .ai-collection-carousel__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-collection-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-collection-carousel__item-{{ ai_gen_id }} {
      height: {{ block.settings.card_height_mobile }}px;
      width: 100%;
    }

    .ai-collection-carousel__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-collection-carousel__button-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_font_size }}px * 0.9);
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<collection-carousel-{{ ai_gen_id }}
  class="ai-collection-carousel-{{ ai_gen_id }}"
  data-autoplay-interval="{{ block.settings.autoplay_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-carousel__wrapper-{{ ai_gen_id }}">
    <div class="ai-collection-carousel__container-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign title_key = 'title_' | append: i
          assign image_key = 'image_' | append: i
          assign collection = block.settings[collection_key]
          assign title = block.settings[title_key]
          assign image = block.settings[image_key]
        %}

        <div class="ai-collection-carousel__item-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-collection-carousel__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-collection-carousel__image-placeholder-{{ ai_gen_id }}">
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-collection-carousel__overlay-{{ ai_gen_id }}"></div>

          <div class="ai-collection-carousel__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-collection-carousel__title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

            {% if collection %}
              <a
                href="{{ collection.url }}"
                class="ai-collection-carousel__button-{{ ai_gen_id }}"
              >
                {{ block.settings.button_text }}
              </a>
            {% else %}
              <a
                href="#"
                class="ai-collection-carousel__button-{{ ai_gen_id }}"
              >
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</collection-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
        this.isTransitioning = false;
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-collection-carousel__container-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-collection-carousel__item-{{ ai_gen_id }}');
        this.totalItems = this.items.length;
        this.interval = parseInt(this.dataset.autoplayInterval) * 1000;

        if (this.totalItems > 2) {
          this.cloneItems();
          this.startAutoplay();
        }
      }

      cloneItems() {
        this.items.forEach((item) => {
          const clone = item.cloneNode(true);
          this.container.appendChild(clone);
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.slideNext();
        }, this.interval);
      }

      slideNext() {
        if (this.isTransitioning) return;

        this.isTransitioning = true;
        this.currentIndex++;

        const itemWidth = this.items[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.container).gap);
        const offset = (itemWidth + gap) * this.currentIndex;

        this.container.style.transform = `translateX(-${offset}px)`;

        if (this.currentIndex >= this.totalItems) {
          setTimeout(() => {
            this.container.style.transition = 'none';
            this.currentIndex = 0;
            this.container.style.transform = 'translateX(0)';
            setTimeout(() => {
              this.container.style.transition = 'transform 0.5s ease-in-out';
              this.isTransitioning = false;
            }, 50);
          }, 500);
        } else {
          setTimeout(() => {
            this.isTransitioning = false;
          }, 500);
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('collection-carousel-{{ ai_gen_id }}', CollectionCarousel{{ ai_gen_id }});
  })();
</script>

